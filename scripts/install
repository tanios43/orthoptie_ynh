#!/bin/bash
source /usr/share/yunohost/helpers

#=================================================
# INSTALL DEPENDENCIES
#=================================================
ynh_script_progression --message="Installation des dépendances Python..." --weight=5

python3 -m venv "$install_dir/venv"
"$install_dir/venv/bin/pip" install --upgrade pip --quiet
"$install_dir/venv/bin/pip" install flask flask-login flask-sqlalchemy flask-wtf pillow gunicorn werkzeug --quiet
# Installer sqlcipher3 si libsqlcipher est disponible
if dpkg -l libsqlcipher0 2>/dev/null | grep -q "^ii"; then
    "$install_dir/venv/bin/pip" install sqlcipher3 --quiet 2>/dev/null || true
fi

#=================================================
# COPY APP FILES
#=================================================
ynh_script_progression --message="Copie des fichiers de l'application..." --weight=1

# Copier les extra_files si présents
if [ -d "$YNH_APP_BASEDIR/sources/extra_files/app" ]; then
    cp -r "$YNH_APP_BASEDIR/sources/extra_files/app/." "$install_dir/"
fi

# Créer le dossier de logs
mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"
chmod 750 "/var/log/$app"
touch "/var/log/$app/backup.log"
chown "$app:$app" "/var/log/$app/backup.log"
chmod 664 "/var/log/$app/backup.log"

# Installer le cron de sauvegarde automatique
if [ -f "$YNH_APP_BASEDIR/conf/backup-cron" ]; then
    cp "$YNH_APP_BASEDIR/conf/backup-cron" "/etc/cron.daily/${app}-backup"
    chmod +x "/etc/cron.daily/${app}-backup"
fi

#=================================================
# CREATE DATA DIRECTORY
#=================================================
ynh_script_progression --message="Création des dossiers de données..." --weight=1

mkdir -p "$data_dir/uploads/wopi"
mkdir -p "$data_dir/uploads/sections"
mkdir -p "$data_dir/uploads/bilans"

# Lien symbolique uploads
rm -rf "$install_dir/uploads"
ln -sf "$data_dir/uploads" "$install_dir/uploads"

# Base de données dans instance/
mkdir -p "$install_dir/instance"
touch "$data_dir/orthoptie_v2.db"
ln -sf "$data_dir/orthoptie_v2.db" "$install_dir/instance/orthoptie_v2.db"

#=================================================
# NGINX CONFIGURATION
#=================================================
ynh_script_progression --message="Configuration de nginx..." --weight=2

ynh_add_nginx_config

#=================================================
# SYSTEMD CONFIGURATION
#=================================================
ynh_script_progression --message="Configuration du service systemd..." --weight=1

ynh_add_systemd_config
yunohost service add "$app" --description="Dossiers Patients Orthoptie" --log="/var/log/$app/$app.log"

#=================================================
# MIGRATION BASE DE DONNÉES
#=================================================
ynh_script_progression --message="Initialisation de la base de données..." --weight=2

pushd "$install_dir"
    # Installer sqlcipher3 si disponible
    if dpkg -l libsqlcipher0 2>/dev/null | grep -q "^ii"; then
        "$install_dir/venv/bin/pip" install sqlcipher3 --quiet 2>/dev/null || true
    fi
    # Créer la base chiffrée vide en premier
    "$install_dir/venv/bin/python3" "$install_dir/encrypt_db.py"
    # Créer toutes les tables dans la base chiffrée
    "$install_dir/venv/bin/python3" -c "from app import app, db
with app.app_context():
    db.create_all()
    print('Tables créées')
"
    # Appliquer les migrations
    "$install_dir/venv/bin/python3" "$install_dir/migrate.py"
popd

#=================================================
# PERMISSIONS
#=================================================
ynh_script_progression --message="Configuration des permissions..." --weight=1

# Générer une clé secrète unique pour Flask
python3 -c "import secrets; print(secrets.token_hex(32))" > "$install_dir/.secret_key"
chmod 600 "$install_dir/.secret_key"
chown "$app:$app" "$install_dir/.secret_key"

# Enregistrer le logo via l'API YunoHost (portail + admin)
if [ -f "$install_dir/doc/LOGO.png" ]; then
    cp "$install_dir/doc/LOGO.png" /usr/share/yunohost/portal/customassets/${app}.png 2>/dev/null || true
    python3 - <<PYEOF
from yunohost.permission import _update_app_permission_setting
try:
    with open('$install_dir/doc/LOGO.png', 'rb') as f:
        _update_app_permission_setting('${app}.main', logo=f)
except Exception as e:
    print(f"Logo update skipped: {e}")
PYEOF
fi

chown -R "$app:www-data" "$install_dir"
chown -R "$app:$app" "$data_dir"
chmod -R o-rwx "$install_dir"
chmod -R o-rwx "$data_dir"

# Script de fix permissions appelable par l'app sans sudo interactif
cat > "/usr/local/bin/orthoptie-fix-perms" << FIXPERMS
#!/bin/bash
chown $app:$app "$data_dir/orthoptie_v2.db" 2>/dev/null
chmod 664 "$data_dir/orthoptie_v2.db" 2>/dev/null
chown -R $app:$app "$data_dir/uploads" 2>/dev/null
chmod -R 755 "$data_dir/uploads" 2>/dev/null
systemctl restart $app
FIXPERMS
chmod +x "/usr/local/bin/orthoptie-fix-perms"

# Script de restauration post-upload (arrêt service + re-chiffrement + redémarrage)
cat > "/usr/local/bin/orthoptie-restore-restart" << RESTARTSCRIPT
#!/bin/bash
DATA_DIR="\${1:-$data_dir}"
INSTALL_DIR="\${2:-$install_dir}"
PYTHON="\$INSTALL_DIR/venv/bin/python3"
ENCRYPT_SCRIPT="\$INSTALL_DIR/encrypt_db.py"
systemctl stop $app 2>/dev/null || true
sleep 1
rm -f "\$DATA_DIR/orthoptie_v2.enc.db"
if [ -f "\$ENCRYPT_SCRIPT" ]; then
    "\$PYTHON" "\$ENCRYPT_SCRIPT"
fi
# Corriger les permissions (important : enc.db peut être créé en root:root)
chown $app:$app "\$DATA_DIR/orthoptie_v2.enc.db" 2>/dev/null || true
chmod 660 "\$DATA_DIR/orthoptie_v2.enc.db" 2>/dev/null || true
chown -R $app:$app "\$DATA_DIR" 2>/dev/null || true
chmod 600 "\$INSTALL_DIR/.db_key" 2>/dev/null || true
systemctl start $app 2>/dev/null || true
RESTARTSCRIPT
chmod +x "/usr/local/bin/orthoptie-restore-restart"

# Règle sudoers
echo "Defaults!/usr/local/bin/orthoptie-restore-restart !use_pty" \
    > "/etc/sudoers.d/orthoptie-fix-perms"
echo "$app ALL=(root) NOPASSWD: /usr/local/bin/orthoptie-fix-perms" \
    >> "/etc/sudoers.d/orthoptie-fix-perms"
echo "$app ALL=(root) NOPASSWD: /usr/local/bin/orthoptie-restore-restart" \
    >> "/etc/sudoers.d/orthoptie-fix-perms"
echo "$app ALL=(root) NOPASSWD: /bin/systemctl restart $app" \
    >> "/etc/sudoers.d/orthoptie-fix-perms"
chmod 440 "/etc/sudoers.d/orthoptie-fix-perms"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression --message="Démarrage du service..." --weight=1

ynh_systemd_action --service_name="$app" --action="start" --log_path="/var/log/$app/$app.log"

ynh_script_progression --message="Installation terminée !" --last
