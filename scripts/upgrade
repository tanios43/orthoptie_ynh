#!/bin/bash
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression --message="Arrêt du service..." --weight=1

ynh_systemd_action --service_name="$app" --action="stop"

#=================================================
# COPY APP FILES
#=================================================
ynh_script_progression --message="Mise à jour des fichiers..." --weight=3

if [ -d "$YNH_APP_BASEDIR/sources/extra_files/app" ]; then
    cp -r "$YNH_APP_BASEDIR/sources/extra_files/app/." "$install_dir/"
fi

#=================================================
# UPDATE DEPENDENCIES
#=================================================
ynh_script_progression --message="Mise à jour des dépendances..." --weight=3

"$install_dir/venv/bin/pip" install --upgrade flask flask-login flask-sqlalchemy flask-wtf pillow gunicorn werkzeug --quiet

#=================================================
# CREATE LOG DIRECTORY
#=================================================
mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"

#=================================================
# MIGRATION BASE DE DONNÉES
#=================================================
ynh_script_progression --message="Migration de la base de données..." --weight=2

pushd "$install_dir"
    "$install_dir/venv/bin/python3" -c "from app import app, db
with app.app_context():
    db.create_all()
"
    "$install_dir/venv/bin/python3" "$install_dir/migrate.py"
popd

#=================================================
# NGINX ET SYSTEMD
#=================================================
ynh_script_progression --message="Mise à jour de la configuration..." --weight=1

ynh_add_nginx_config
ynh_add_systemd_config

#=================================================
# PERMISSIONS
#=================================================
chown -R "$app:www-data" "$install_dir"
chown -R "$app:$app" "$data_dir"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression --message="Redémarrage du service..." --weight=1

ynh_systemd_action --service_name="$app" --action="start" --log_path="/var/log/$app/$app.log"

ynh_script_progression --message="Mise à jour terminée !" --last
