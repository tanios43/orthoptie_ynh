#!/bin/bash
# Script de sauvegarde automatique quotidienne — Orthoptie

APP="orthoptie"
DATA_DIR="/home/yunohost.app/${APP}"
BACKUP_DIR="${DATA_DIR}/backups"
SSH_KEY="${DATA_DIR}/ssh/backup_key"
MAX_BACKUPS=7

mkdir -p "${BACKUP_DIR}"
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/orthoptie_backup_${DATE}.tar.gz"

tar -czf "${BACKUP_FILE}" -C "${DATA_DIR}" "orthoptie_v2.db" "uploads" 2>/dev/null

if [ $? -eq 0 ]; then
    echo "Sauvegarde créée : ${BACKUP_FILE}"
else
    echo "Erreur lors de la sauvegarde" >&2
    exit 1
fi

# Rotation locale
ls -t "${BACKUP_DIR}"/orthoptie_backup_*.tar.gz 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | xargs -r rm --
echo "Rotation effectuée — ${MAX_BACKUPS} sauvegardes conservées"

# Envoi SFTP/rsync si configuré et activé
SFTP_CONFIG="${DATA_DIR}/sftp_config.sh"
if [ -f "${SFTP_CONFIG}" ]; then
    source "${SFTP_CONFIG}"
    if [ "${SFTP_ACTIF}" = "1" ] && [ -n "${SFTP_HOST}" ] && [ -f "${SSH_KEY}" ]; then
        echo "Envoi vers ${SFTP_USER}@${SFTP_HOST}:${SFTP_PATH}..."
        rsync -az --timeout=60 \
            -e "ssh -i ${SSH_KEY} -p ${SFTP_PORT:-22} -o StrictHostKeyChecking=no -o BatchMode=yes" \
            "${BACKUP_FILE}" \
            "${SFTP_USER}@${SFTP_HOST}:${SFTP_PATH}/"
        if [ $? -eq 0 ]; then
            echo "Sauvegarde distante OK"
        else
            echo "Erreur envoi distant" >&2
        fi
    fi
fi
