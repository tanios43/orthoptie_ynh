#!/bin/bash
# Script de sauvegarde automatique quotidienne — Orthoptie
# Installé par le package YunoHost dans /etc/cron.daily/orthoptie-backup

APP="orthoptie"
DATA_DIR="/home/yunohost.app/${APP}"
INSTALL_DIR="/var/www/${APP}"
BACKUP_DIR="${DATA_DIR}/backups"
DB_PATH="${DATA_DIR}/orthoptie_v2.db"
UPLOADS_DIR="${DATA_DIR}/uploads"
MAX_BACKUPS=7

mkdir -p "${BACKUP_DIR}"

DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/orthoptie_backup_${DATE}.zip"

# Créer le zip
zip -r "${BACKUP_FILE}" "${DB_PATH}" "${UPLOADS_DIR}" > /dev/null 2>&1

if [ $? -eq 0 ]; then
    echo "Sauvegarde créée : ${BACKUP_FILE}"
else
    echo "Erreur lors de la sauvegarde" >&2
    exit 1
fi

# Rotation — garder seulement les MAX_BACKUPS dernières
ls -t "${BACKUP_DIR}"/orthoptie_backup_*.zip 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | xargs -r rm --

echo "Rotation effectuée — ${MAX_BACKUPS} sauvegardes conservées"
